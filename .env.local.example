# ============================================================
# PickMyPath — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to GitHub.
# Add ALL of these to Vercel → Project Settings → Environment Variables.
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# From: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── FIREBASE (Google Sign-In) ─────────────────────────────────
# From: console.firebase.google.com → Project settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ── ANTHROPIC (AI report generation) ─────────────────────────
# From: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...
# Model: use claude-haiku-4-5-20251001 for testing (cheap), claude-sonnet-4-6 for production (best quality)
AI_MODEL=claude-haiku-4-5-20251001

# ── GOOGLE OAUTH ──────────────────────────────────────────────
# From: console.cloud.google.com → OAuth 2.0 Client Credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# ── PAYFAST (South African payment gateway) ──────────────────
# From: merchant.payfast.co.za → Dashboard → API Keys
# Leave blank while testing — sandbox mode is used automatically
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_MERCHANT_KEY=your_merchant_key
# Set to 'false' only when you are ready for real live payments
NEXT_PUBLIC_PAYFAST_SANDBOX=true

# ── ADMIN PANEL ───────────────────────────────────────────────
# You choose these — use your own email and a strong password
ADMIN_EMAIL=admin@yourdomain.co.za
ADMIN_PASSWORD=choose-a-very-strong-password

# ── APP CONFIG ────────────────────────────────────────────────
# Your live Vercel URL (update once you have a custom domain)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate-a-random-64-char-string-here

# ── PRICING ───────────────────────────────────────────────────
NEXT_PUBLIC_ASSESSMENT_PRICE=399
NEXT_PUBLIC_VAT_RATE=15

# ── EMAIL (Domains.co.za) ────────────────────────────────────────────
# Create a mail account in domains.co.za cPanel, then add these env vars
SMTP_HOST=mail.pickmypath.co.za
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@pickmypath.co.za
SMTP_PASS=your_smtp_password_here
